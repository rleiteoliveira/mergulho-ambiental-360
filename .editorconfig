root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

[*.{json,md,yml,yaml}]
indent_style = space
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 2

[*.unity]
trim_trailing_whitespace = false

[*.prefab]
trim_trailing_whitespace = false

[*.asset]
trim_trailing_whitespace = false

[*.meta]
trim_trailing_whitespace = false
